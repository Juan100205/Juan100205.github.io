---
import Layout from "../layouts/Layout.astro";
---
<Layout title="404 Not Found">
    <style>
        .headers {
            position: relative;
            padding: 10px;
            display: flex;
            color: white;
            height: 1000px;
            background-size: cover;
            background-position: center;
            align-items: center;
            justify-content: center; /* Centrar horizontalmente */
            overflow: hidden; /* Para asegurarse de que el pseudo-elemento no se salga del contenedor */
        }
        
        .headers::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('/404error.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.5; /* Opacidad de la imagen de fondo */
            z-index: 1;
        }

        .col {
            position: relative;
            z-index: 2; /* Asegura que el contenido esté por encima de la imagen de fondo */
            text-align: center; 
            font-size: 60px;
            font-weight: bold;
        }
    </style>
    <div class="headers">
        <div class="col"style="opacity:1;color:#2F3782">
            <h2>Lo sentimos, estamos trabajando en ello.</h2>
            
        </div>
    </div>
</Layout>
